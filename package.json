{
  "name": "@vaur94/mcpbase",
  "version": "2.0.0",
  "description": "Stdio-first reference repository for future MCP servers.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcpbase": "./bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./examples": {
      "types": "./dist/examples/index.d.ts",
      "import": "./dist/examples/index.js",
      "default": "./dist/examples/index.js"
    },
    "./security": {
      "types": "./dist/security/index.d.ts",
      "import": "./dist/security/index.js",
      "default": "./dist/security/index.js"
    },
    "./hub": {
      "types": "./dist/hub/index.d.ts",
      "import": "./dist/hub/index.js",
      "default": "./dist/hub/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=10.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "@semantic-release/npm": "^13.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaur94/mcpbase.git"
  },
  "bugs": {
    "url": "https://github.com/vaur94/mcpbase/issues"
  },
  "homepage": "https://github.com/vaur94/mcpbase#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "typescript",
    "stdio",
    "reference-architecture",
    "template"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "clean": "rimraf coverage dist .turbo",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit tests/integration",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:protocol": "npm run build && vitest run tests/protocol",
    "test:coverage": "vitest run tests/unit tests/integration --coverage",
    "ci:check": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run test:protocol",
    "release": "semantic-release",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.27.1",
    "zod": ">=3.23.0 || >=4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.1.0"
  }
}
